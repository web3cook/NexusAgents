apiVersion: batch/v1
kind: Job
metadata:
  name: {{ name }}-migration
  namespace: {{ namespace }}
spec:
  template:
    spec:
      containers:
        - name: migrate
          image: {{ image }}
          command: ["alembic", "upgrade", "head"]
          env:
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: {{ namespace }}-secrets
                  key: database-url
      restartPolicy: Never
  backoffLimit: 3
